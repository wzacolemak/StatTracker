# 本地路径配置模板
# 复制本文件为 .env,填入你自己的路径后即可构建:
#   cp .env.example .env
#
# Local path config template.
# Copy to .env and fill in your own paths, then build.

# Java 8 的根目录(JDK8,含 bin/javac)
# Java 8 home (contains bin/javac)
STS_JDK8="/path/to/jdk8"

# 杀戮尖塔游戏目录(含 desktop-1.0.jar)
# Slay the Spire game dir (contains desktop-1.0.jar)
STS_GAME="/path/to/SlayTheSpire"

# Steam 创意工坊目录(放 ModTheSpire/BaseMod 等依赖)
# Steam workshop dir (contains ModTheSpire/BaseMod/etc.)
STS_WORKSHOP="/path/to/steamapps/workshop/content/646570"
